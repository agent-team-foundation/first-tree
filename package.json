{
  "name": "first-tree-monorepo",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "check": "biome check .",
    "lint": "biome lint .",
    "format": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "coverage": "turbo run coverage",
    "coverage:summary": "node scripts/coverage-summary.mjs",
    "e2e:doctor": "turbo run e2e:doctor --filter=@first-tree/e2e",
    "e2e:smoke": "turbo run e2e:smoke --filter=@first-tree/e2e",
    "e2e:full": "turbo run e2e:full --filter=@first-tree/e2e",
    "e2e:up": "pnpm --filter @first-tree/e2e e2e:up",
    "e2e:clean": "pnpm --filter @first-tree/e2e e2e:clean",
    "validate:skill": "python3 ./scripts/quick_validate_skill.py ./skills/first-tree-welcome && python3 ./scripts/quick_validate_skill.py ./skills/first-tree-repo-work && python3 ./scripts/quick_validate_skill.py ./skills/first-tree-write && python3 ./scripts/quick_validate_skill.py ./skills/first-tree-read && python3 ./scripts/quick_validate_skill.py ./skills/first-tree-seed"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
