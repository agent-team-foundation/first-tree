{
  "name": "first-tree-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.16.0"
  },
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "check": "biome check .",
    "format": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "e2e:doctor": "turbo run e2e:doctor --filter=@first-tree/e2e",
    "e2e:smoke": "turbo run e2e:smoke --filter=@first-tree/e2e",
    "e2e:full": "turbo run e2e:full --filter=@first-tree/e2e",
    "e2e:up": "pnpm --filter @first-tree/e2e e2e:up",
    "e2e:clean": "pnpm --filter @first-tree/e2e e2e:clean",
    "validate:skill": "python3 ./skills/first-tree-hub/scripts/quick_validate.py ./skills/first-tree-hub && bash ./skills/first-tree-hub/scripts/check-skill-sync.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  }
}
