FROM node:24-alpine AS deps
RUN apk add --no-cache python3 make g++
RUN corepack enable
WORKDIR /app

# Copy package manifests for dependency layer caching
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY packages/shared/package.json packages/shared/
COPY packages/client/package.json packages/client/
COPY packages/command/package.json packages/command/
RUN pnpm install --frozen-lockfile

# --- Build stage ---
FROM deps AS build
COPY . .
RUN pnpm build

# --- Production dependencies ---
FROM deps AS prod-deps
RUN pnpm install --frozen-lockfile --prod

# --- Runtime ---
FROM node:24-alpine
WORKDIR /app

# Production node_modules
COPY --from=prod-deps /app ./

# Build artifacts (client needs shared + client + command)
COPY --from=build /app/packages/shared/dist packages/shared/dist/
COPY --from=build /app/packages/client/dist packages/client/dist/
COPY --from=build /app/packages/command/dist packages/command/dist/

ENV NODE_ENV=production

CMD ["node", "packages/command/dist/cli/index.mjs", "client", "start", "--no-interactive"]
