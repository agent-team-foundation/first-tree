# Database
DATABASE_URL=postgresql+psycopg://agenthub:agenthub@localhost:5432/agenthub

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Admin JWT (生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET_KEY=

# Adapter 凭证加密密钥 (生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))")
ENCRYPTION_KEY=

# Docker Compose (可选, 覆盖 docker-compose.yml 默认值)
# POSTGRES_DB=agenthub
# POSTGRES_USER=agenthub
# POSTGRES_PASSWORD=agenthub
# POSTGRES_PORT=5432
