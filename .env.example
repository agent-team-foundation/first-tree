# =============================================================================
# First Tree Hub — Environment Variables
# Copy this file: cp .env.example .env
# =============================================================================

# ┌───────────────────────────────────────────────────────────────────────────┐
# │ Server — Required (Docker / CI / --no-interactive)                       │
# │ Interactive mode will prompt for these if not set.                       │
# └───────────────────────────────────────────────────────────────────────────┘

# PostgreSQL connection URL
# Docker Compose: provided automatically by the postgres service
# Supabase: use the direct connection (port 5432), NOT pooled (port 6543)
FIRST_TREE_HUB_DATABASE_URL=postgresql://firsttreehub:firsttreehub@localhost:5432/firsttreehub

# Bind address — MUST be 0.0.0.0 for Docker; default 127.0.0.1 for local
FIRST_TREE_HUB_HOST=0.0.0.0

# Context Tree GitHub repository (URL or owner/repo format, optional)
# FIRST_TREE_HUB_CONTEXT_TREE_REPO=org/first-tree

# ┌───────────────────────────────────────────────────────────────────────────┐
# │ Server — Optional (have defaults or are auto-generated)                  │
# └───────────────────────────────────────────────────────────────────────────┘

# Server port (default: 8000)
# FIRST_TREE_HUB_PORT=8000

# GitHub webhook secret (only needed if using GitHub webhooks)
# Must match the value in your GitHub repo webhook settings
# FIRST_TREE_HUB_GITHUB_WEBHOOK_SECRET=

# JWT signing secret for admin authentication (auto-generated if not set)
# FIRST_TREE_HUB_JWT_SECRET=

# AES-256-GCM encryption key for adapter credentials (auto-generated if not set)
# FIRST_TREE_HUB_ENCRYPTION_KEY=

# Default admin password (auto-generated and printed on first start if not set)
# FIRST_TREE_HUB_ADMIN_PASSWORD=

# CORS allowed origins (comma-separated)
# FIRST_TREE_HUB_CORS_ORIGIN=https://app.example.com

# Rate limiting (requests per minute per IP)
# FIRST_TREE_HUB_RATE_LIMIT_MAX=100
# FIRST_TREE_HUB_RATE_LIMIT_LOGIN_MAX=5
# FIRST_TREE_HUB_RATE_LIMIT_WEBHOOK_MAX=60

# ┌───────────────────────────────────────────────────────────────────────────┐
# │ Client — Required (for first-tree-hub client start)                           │
# └───────────────────────────────────────────────────────────────────────────┘

# Server URL the client connects to
# FIRST_TREE_HUB_SERVER_URL=https://hub.example.com

# ┌───────────────────────────────────────────────────────────────────────────┐
# │ Client — Optional                                                        │
# └───────────────────────────────────────────────────────────────────────────┘

# Log level (debug | info | warn | error, default: info)
# FIRST_TREE_HUB_LOG_LEVEL=info

# ┌───────────────────────────────────────────────────────────────────────────┐
# │ Docker Compose                                                           │
# │ Used by docker-compose.production.yml and deploy/docker-compose.caddy.yml│
# └───────────────────────────────────────────────────────────────────────────┘

# PostgreSQL credentials (for compose-managed PG)
# POSTGRES_USER=firsttreehub
# POSTGRES_PASSWORD=firsttreehub
# POSTGRES_DB=firsttreehub

# Domain name (required for deploy/docker-compose.caddy.yml HTTPS)
# DOMAIN=hub.example.com
