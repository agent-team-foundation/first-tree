# =============================================================================
# Agent Hub — Environment Variables
# Copy this file: cp .env.example .env
# =============================================================================

# === Required ===

# Context Tree GitHub repository (URL or owner/repo format)
AGENT_HUB_CONTEXT_TREE_REPO=org/first-tree

# GitHub personal access token (repo scope required)
# Create at: https://github.com/settings/tokens
AGENT_HUB_GITHUB_TOKEN=

# GitHub webhook secret (must match the value set in your GitHub repo webhook settings)
# AGENT_HUB_GITHUB_WEBHOOK_SECRET=

# === Database ===

# PostgreSQL connection URL
# If not set, the CLI will auto-provision a Docker PostgreSQL container
# For Supabase: use the direct connection URL (port 5432), NOT the pooled URL (port 6543)
AGENT_HUB_DATABASE_URL=postgresql://agenthub:agenthub@localhost:5432/agenthub

# === Server ===

# Server port (default: 8000)
AGENT_HUB_PORT=8000

# Bind address (default: 127.0.0.1, use 0.0.0.0 for Docker/public access)
AGENT_HUB_HOST=127.0.0.1

# === Secrets (auto-generated if not set) ===

# JWT signing secret for admin authentication
# AGENT_HUB_JWT_SECRET=

# AES-256-GCM encryption key for adapter credentials
# AGENT_HUB_ENCRYPTION_KEY=

# Default admin password (prompted interactively if not set)
# AGENT_HUB_ADMIN_PASSWORD=

# === Optional ===

# CORS allowed origins (comma-separated, e.g. https://app.example.com,https://admin.example.com)
# AGENT_HUB_CORS_ORIGIN=

# Rate limiting (requests per minute per IP)
# AGENT_HUB_RATE_LIMIT_MAX=100
# AGENT_HUB_RATE_LIMIT_LOGIN_MAX=5
# AGENT_HUB_RATE_LIMIT_WEBHOOK_MAX=60

# === Client (for agent-hub client start) ===

# Server URL the client connects to
# AGENT_HUB_SERVER_URL=http://localhost:8000

# Client log level (debug | info | warn | error)
# AGENT_HUB_LOG_LEVEL=info

# === Docker Compose ===
# Used by docker-compose.production.yml and deploy/docker-compose.caddy.yml

# PostgreSQL credentials (for docker-compose managed PG)
# POSTGRES_USER=agenthub
# POSTGRES_PASSWORD=agenthub
# POSTGRES_DB=agenthub

# Domain name (required for deploy/docker-compose.caddy.yml HTTPS)
# DOMAIN=hub.example.com
