# Database
AGENT_HUB_DATABASE_URL=postgresql://agenthub:agenthub@localhost:5432/agenthub

# Server
AGENT_HUB_HOST=127.0.0.1
AGENT_HUB_PORT=8000

# Secrets (auto-generated on first `agent-hub server start` if not set)
AGENT_HUB_JWT_SECRET=
AGENT_HUB_ENCRYPTION_KEY=

# Admin (optional — if not set, a random password is generated and printed on first start)
# AGENT_HUB_ADMIN_PASSWORD=

# Context Tree
AGENT_HUB_CONTEXT_TREE_REPO=org/first-tree
AGENT_HUB_GITHUB_TOKEN=

# Web admin console static files (auto-resolved in production)
# AGENT_HUB_WEB_DIST_PATH=

# Docker Compose (optional, overrides for docker-compose.yml)
# POSTGRES_DB=agenthub
# POSTGRES_USER=agenthub
# POSTGRES_PASSWORD=agenthub
# POSTGRES_PORT=5432
