# Database
DATABASE_URL=postgresql://agenthub:agenthub@localhost:5432/agenthub

# Server
HOST=127.0.0.1
PORT=8000

# Secrets (auto-generated on first `agent-hub server start` if not set)
JWT_SECRET=
ENCRYPTION_KEY=

# Context Tree (P1 — GitHub GraphQL sync)
# CONTEXT_TREE_REPO=org/first-tree
# GITHUB_TOKEN=

# GitHub Webhook (optional — if not set, signature verification is skipped)
# GITHUB_WEBHOOK_SECRET=

# Web admin console static files (auto-resolved in production)
# WEB_DIST_PATH=

# Docker Compose (optional, overrides for docker-compose.yml)
# POSTGRES_DB=agenthub
# POSTGRES_USER=agenthub
# POSTGRES_PASSWORD=agenthub
# POSTGRES_PORT=5432
