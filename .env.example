# =============================================================================
# Agent Hub — Environment Variables
# Copy this file: cp .env.example .env
# =============================================================================

# ┌───────────────────────────────────────────────────────────────────────────┐
# │ Server — Required (Docker / CI / --no-interactive)                       │
# │ Interactive mode will prompt for these if not set.                       │
# └───────────────────────────────────────────────────────────────────────────┘

# PostgreSQL connection URL
# Docker Compose: provided automatically by the postgres service
# Supabase: use the direct connection (port 5432), NOT pooled (port 6543)
AGENT_HUB_DATABASE_URL=postgresql://agenthub:agenthub@localhost:5432/agenthub

# Bind address — MUST be 0.0.0.0 for Docker; default 127.0.0.1 for local
AGENT_HUB_HOST=0.0.0.0

# Context Tree GitHub repository (URL or owner/repo format)
AGENT_HUB_CONTEXT_TREE_REPO=org/first-tree

# GitHub personal access token (repo scope)
# Create at: https://github.com/settings/tokens
AGENT_HUB_GITHUB_TOKEN=

# GitHub webhook secret (must match the value in your GitHub repo webhook settings)
AGENT_HUB_GITHUB_WEBHOOK_SECRET=

# ┌───────────────────────────────────────────────────────────────────────────┐
# │ Server — Optional (have defaults or are auto-generated)                  │
# └───────────────────────────────────────────────────────────────────────────┘

# Server port (default: 8000)
# AGENT_HUB_PORT=8000

# JWT signing secret for admin authentication (auto-generated if not set)
# AGENT_HUB_JWT_SECRET=

# AES-256-GCM encryption key for adapter credentials (auto-generated if not set)
# AGENT_HUB_ENCRYPTION_KEY=

# Default admin password (auto-generated and printed on first start if not set)
# AGENT_HUB_ADMIN_PASSWORD=

# CORS allowed origins (comma-separated)
# AGENT_HUB_CORS_ORIGIN=https://app.example.com

# Rate limiting (requests per minute per IP)
# AGENT_HUB_RATE_LIMIT_MAX=100
# AGENT_HUB_RATE_LIMIT_LOGIN_MAX=5
# AGENT_HUB_RATE_LIMIT_WEBHOOK_MAX=60

# ┌───────────────────────────────────────────────────────────────────────────┐
# │ Client — Required (for agent-hub client start)                           │
# └───────────────────────────────────────────────────────────────────────────┘

# Server URL the client connects to
# AGENT_HUB_SERVER_URL=https://hub.example.com

# ┌───────────────────────────────────────────────────────────────────────────┐
# │ Client — Optional                                                        │
# └───────────────────────────────────────────────────────────────────────────┘

# Log level (debug | info | warn | error, default: info)
# AGENT_HUB_LOG_LEVEL=info

# ┌───────────────────────────────────────────────────────────────────────────┐
# │ Docker Compose                                                           │
# │ Used by docker-compose.production.yml and deploy/docker-compose.caddy.yml│
# └───────────────────────────────────────────────────────────────────────────┘

# PostgreSQL credentials (for compose-managed PG)
# POSTGRES_USER=agenthub
# POSTGRES_PASSWORD=agenthub
# POSTGRES_DB=agenthub

# Domain name (required for deploy/docker-compose.caddy.yml HTTPS)
# DOMAIN=hub.example.com
