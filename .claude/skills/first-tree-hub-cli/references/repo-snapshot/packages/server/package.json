{
  "name": "@first-tree-hub/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/app.ts",
      "import": "./dist/app.mjs"
    },
    "./config": "./src/config.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsdown src/index.ts src/app.ts --format esm --no-dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "admin:create": "tsx src/scripts/create-admin.ts"
  },
  "dependencies": {
    "@first-tree-hub/shared": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "bcrypt": "^6.0.0",
    "drizzle-orm": "^0.44.0",
    "fastify": "^5.3.0",
    "gray-matter": "^4.0.3",
    "jose": "^6.0.0",
    "postgres": "^3.4.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@first-tree-hub/client": "workspace:*",
    "@testcontainers/postgresql": "^11.13.0",
    "@types/bcrypt": "^5.0.0",
    "@types/node": "^22.16.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.0",
    "testcontainers": "^11.13.0",
    "tsdown": "^0.21.4",
    "tsx": "^4.19.0",
    "vitest": "^3.2.0",
    "ws": "^8.20.0"
  }
}
