#!/usr/bin/env bash
# breeze setup — installs the Claude Code skill symlinks and bootstraps
# the TypeScript daemon.
#
# As of Phase 9 this script no longer builds any Rust binaries and no
# longer writes launchd plists directly — daemon lifecycle is handled by
# `first-tree breeze start` / `first-tree breeze stop`.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BREEZE_DIR="${BREEZE_DIR:-$HOME/.breeze}"
SKILL_DIR="$HOME/.claude/skills"

echo "=== breeze setup ==="
echo ""

# 1. Check prerequisites (gh + jq).
echo "Checking prerequisites..."

if ! command -v gh &>/dev/null; then
  echo "ERROR: gh CLI is not installed. Install it: https://cli.github.com/"
  exit 1
fi

if ! gh auth status &>/dev/null; then
  echo "ERROR: gh is not authenticated. Run 'gh auth login' first."
  exit 1
fi

if ! command -v jq &>/dev/null; then
  echo "ERROR: jq is not installed. Install it: brew install jq (macOS) or apt install jq (Linux)"
  exit 1
fi

if ! command -v first-tree &>/dev/null; then
  echo "ERROR: first-tree CLI is not on PATH. Install with: npm i -g first-tree"
  exit 1
fi

echo "  gh CLI: OK"
echo "  jq: OK"
echo "  first-tree: OK"
echo ""

# 2. Create breeze directory and default config.
echo "Setting up ~/.breeze..."
mkdir -p "$BREEZE_DIR"

if [ ! -f "$BREEZE_DIR/config.yaml" ]; then
  cat > "$BREEZE_DIR/config.yaml" << 'EOF'
# breeze configuration
poll_interval_sec: 60
task_timeout_sec: 1800
log_level: info
http_port: 7878
host: github.com
EOF
  echo "  Created default config at $BREEZE_DIR/config.yaml"
else
  echo "  Config already exists at $BREEZE_DIR/config.yaml"
fi
echo ""

# 3. Install Claude Code skill symlinks.
echo "Installing Claude Code skills..."
mkdir -p "$SKILL_DIR"
for pair in \
  "breeze:skill" \
  "breeze-watch:skill-watch" \
  "breeze-upgrade:skill-upgrade"; do
  name="${pair%%:*}"
  src="${pair#*:}"
  target="$SKILL_DIR/$name"
  source_path="$SCRIPT_DIR/$src"
  if [ ! -d "$source_path" ]; then
    echo "  WARN: $source_path missing; skipping $name"
    continue
  fi
  if [ -L "$target" ] || [ -d "$target" ]; then
    rm -rf "$target"
  fi
  ln -s "$source_path" "$target"
  echo "  Symlinked $target -> $source_path"
done
echo ""

# 4. Start the TypeScript daemon in the background. `first-tree breeze start`
#    handles launchd (macOS) or detached-spawn fallback (Linux/other).
echo "Starting the breeze daemon..."
if first-tree breeze start; then
  echo "  Daemon started"
else
  echo "  WARN: daemon start failed; run \`first-tree breeze start\` manually"
fi
echo ""

echo "=== breeze setup complete ==="
echo ""
echo "  Dashboard:  http://127.0.0.1:7878"
echo "  Status:     first-tree breeze status"
echo "  Stop:       first-tree breeze stop"
echo "  Inspect:    first-tree breeze doctor"
