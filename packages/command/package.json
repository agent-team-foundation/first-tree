{
  "name": "@agent-team-foundation/first-tree-hub",
  "version": "0.14.9",
  "type": "module",
  "description": "First Tree Hub — unified CLI for client and agent management",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs"
    }
  },
  "bin": {
    "first-tree-hub": "./dist/cli/index.mjs"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsdown src/cli/index.ts src/index.ts --format esm --no-dts --external @anthropic-ai/claude-agent-sdk --external @openai/codex-sdk",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agent-team-foundation/first-tree-hub.git",
    "directory": "packages/command"
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.84",
    "@openai/codex-sdk": "^0.125.0",
    "@inquirer/prompts": "^8.3.0",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "commander": "^13.1.0",
    "gray-matter": "^4.0.3",
    "jose": "^6.0.0",
    "semver": "^7.6.3",
    "ws": "^8.20.0",
    "yaml": "^2.8.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@first-tree-hub/client": "workspace:*",
    "@first-tree-hub/server": "workspace:*",
    "@agent-team-foundation/first-tree-hub-shared": "workspace:*",
    "@first-tree-hub/web": "workspace:*",
    "@types/node": "^22.16.0",
    "@types/semver": "^7.5.8",
    "postgres": "^3.4.0",
    "tsdown": "^0.21.4",
    "tsx": "^4.21.0",
    "vitest": "^3.2.0"
  }
}
