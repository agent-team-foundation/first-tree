{
  "name": "@unispark.ai/agent-hub",
  "version": "0.1.0",
  "type": "module",
  "description": "Agent Hub — unified CLI for server, client, and agent management",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "bin": {
    "agent-hub": "./dist/cli/index.mjs"
  },
  "files": [
    "dist",
    "templates"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsdown src/index.ts src/cli/index.ts --format esm --dts.eager",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agent-team-foundation/agent-hub.git",
    "directory": "packages/command"
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@agent-hub/client": "workspace:*",
    "@agent-hub/server": "workspace:*",
    "@agent-hub/shared": "workspace:*",
    "@agent-hub/web": "workspace:*",
    "@types/bcrypt": "^5.0.0",
    "@types/node": "^22.16.0",
    "bcrypt": "^6.0.0",
    "drizzle-orm": "^0.44.0",
    "postgres": "^3.4.0",
    "tsdown": "^0.21.4",
    "vitest": "^3.2.0"
  }
}
