# Copy to .env.e2e (git-ignored) and adjust as needed.
# All vars are optional unless a default would be unsafe.

# PostgreSQL container image. Pin a digest in CI; alpine for local speed.
E2E_PG_IMAGE=postgres:16-alpine

# Retain framework run logs locally on success too (default: only on failure).
E2E_KEEP_LOGS=0

# Override the per-run ID. Default is a short random hash.
# E2E_RUN_ID=fixed-1

# Override the dynamic port allocation range (defaults to 30000–40000).
# E2E_PORT_MIN=30000
# E2E_PORT_MAX=40000

# Docker compose binary. Auto-detected: prefers `docker compose` (v2),
# falls back to `docker-compose` (v1).
# E2E_DOCKER_COMPOSE_BIN=docker compose
