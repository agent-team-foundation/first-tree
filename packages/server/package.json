{
  "name": "@first-tree/server",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/app.ts",
      "import": "./dist/app.mjs"
    },
    "./config": "./src/config.ts",
    "./observability": {
      "types": "./src/observability/index.ts",
      "import": "./dist/observability/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "FIRST_TREE_DEV_CALLBACK_ENABLED=1 tsx watch --env-file=../../.env src/index.ts",
    "build": "tsdown src/index.ts src/app.ts src/observability/index.ts --format esm --no-dts && node ../../scripts/copy-server-prompts.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate && node ../../scripts/sync-migration-head.mjs",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@autotelic/fastify-opentelemetry": "^0.23.0",
    "@aws-sdk/client-s3": "^3.1093.0",
    "@aws-sdk/s3-request-presigner": "^3.1093.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "@first-tree/shared": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@pydantic/logfire-node": "^0.14.0",
    "bcrypt": "^6.0.0",
    "croner": "10.0.1",
    "drizzle-orm": "^0.44.0",
    "ejs": "^6.0.1",
    "fastify": "^5.3.0",
    "gray-matter": "^4.0.3",
    "ipaddr.js": "^2.3.0",
    "jose": "^6.0.0",
    "pino": "^9.5.0",
    "postgres": "^3.4.0",
    "semver": "^7.7.4",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@first-tree/client": "workspace:*",
    "@opentelemetry/context-async-hooks": "^2.7.0",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@testcontainers/postgresql": "^11.13.0",
    "@types/bcrypt": "^5.0.0",
    "@types/ejs": "^3.1.5",
    "@types/node": "^22.16.0",
    "@types/semver": "^7.7.1",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "3.2.4",
    "drizzle-kit": "^0.31.0",
    "testcontainers": "^11.13.0",
    "tsdown": "^0.21.4",
    "tsx": "^4.19.0",
    "vitest": "^3.2.0",
    "ws": "^8.20.0"
  }
}
