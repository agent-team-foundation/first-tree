{
  "name": "@first-tree-hub/client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "First Tree Hub SDK — programmatic client for First Tree Hub server",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --no-dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.84",
    "ws": "^8.20.0",
    "yaml": "^2.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@first-tree-hub/shared": "workspace:*",
    "@types/node": "^22.16.0",
    "@types/ws": "^8.18.1",
    "tsdown": "^0.21.4",
    "vitest": "^3.2.0"
  }
}
