# Playwright MCP
.playwright-mcp/
# Per-workspace runtime binding state. Under the W1 workspace-rooted layout
# this directory holds only client-managed runtime artifacts (none of which
# belong in source control); pre-W1 callers used to commit `source.json` /
# `local-tree.json` / `tmp/` here.
.first-tree/

# Local dev CLI shim (generated by run_client.sh to resolve `first-tree-hub`
# to the repo's dist instead of the globally installed release).
.local-bin/
.dev/
