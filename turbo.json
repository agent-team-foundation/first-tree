{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {},
    "e2e:doctor": {
      "cache": false,
      "passThroughEnv": ["E2E_*", "FIRST_TREE_HUB_*"]
    },
    "e2e:smoke": {
      "dependsOn": ["^build"],
      "cache": false,
      "passThroughEnv": ["E2E_*", "FIRST_TREE_HUB_*"]
    },
    "e2e:full": {
      "dependsOn": ["^build"],
      "cache": false,
      "passThroughEnv": ["E2E_*", "FIRST_TREE_HUB_*"]
    }
  }
}
