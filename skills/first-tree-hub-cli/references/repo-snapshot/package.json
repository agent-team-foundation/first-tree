{
  "name": "first-tree-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.16.0"
  },
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "check": "biome check .",
    "format": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "validate:skill": "python3 ./skills/first-tree-hub-cli/scripts/quick_validate.py ./skills/first-tree-hub-cli && bash ./skills/first-tree-hub-cli/scripts/check-skill-sync.sh && bash ./skills/first-tree-hub-cli/scripts/portable-smoke-test.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  }
}
